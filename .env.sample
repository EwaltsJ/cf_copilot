# Registry & Model
LOCAL_REGISTRY_PATH=raw_data
MODEL_TARGET=local
GCS_BUCKET_NAME=cf_copilot_bucket
GCS_MODEL_PREFIX=cf_copilot

# MLflow
MLFLOW_TRACKING_URI=https://mlflow.lewagon.ai
MLFLOW_EXPERIMENT=cf_copilot_experiment_<your_github_nickname>
MLFLOW_MODEL_NAME=cf_copilot_<your_github_nickname>

# GCP
GCP_PROJECT_ID=your_project_name_here
GCP_REGION=europe-west1

# Docker
DOCKER_IMAGE_NAME=cf-copilot-image
DOCKER_REPO_NAME=cf-copilot-repo

# Playbook / RAG
BASE_DIR=
PLAYBOOK_PATH=data/playbook
CHROMA_PATH=data/chroma_db

# API
API_URL=http://localhost:8080
ENV=development

# Other
CURRENT_DATE=2020-05-22
GEMINI_API_KEY=your-api-key
